# Server
PORT=3000

# Optional OpenAI integration
# Leave blank for local offline answers. Set in production for AI-generated answers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=8000

# OAuth / account login
APP_ID=
APP_SECRET=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# Browser-exposed OAuth settings
VITE_KIMI_AUTH_URL=
VITE_APP_ID=

# Database
DATABASE_URL=

# Local manual testing
# This enables the "Try local demo" button in built preview.
VITE_ENABLE_DEMO_LOGIN=false

# This lets the built server run locally without production secrets.
EMBEDDEDGPT_LOCAL_TEST=false
